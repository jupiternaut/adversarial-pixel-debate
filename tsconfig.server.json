{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "outDir": "dist-server",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": ["server/**/*.ts", "shared/**/*.ts"]
}
